# Comma-separated list of AdGuard Home servers (host or host:port).
# Example: 192.168.1.1,192.168.1.2:3000,adguard.example.com
ADGUARD_SERVERS=192.168.1.1

# URL scheme for all AdGuard Home servers (http or https). Default: http
ADGUARD_SCHEME=http

# AdGuard Home credentials. Leave empty if authentication is disabled.
ADGUARD_USER=admin
ADGUARD_PASSWORD=your-adguard-password-here

# Skip TLS certificate verification (useful for self-signed certs). Default: false
ADGUARD_TLS_SKIP_VERIFY=false

# Bearer token callers must present to use this API.
GATEWAY_API_KEY=your-gateway-api-key-here

# Port this gateway listens on. Default: 8080
PORT=8080

# Log level: debug, info, warn, error. Default: info
LOG_LEVEL=info
